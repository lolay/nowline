{
    "private": true,
    "name": "nowline-monorepo",
    "packageManager": "pnpm@10.33.4",
    "scripts": {
        "build": "pnpm -r run build && node scripts/render.mjs",
        "render": "node scripts/render.mjs",
        "samples": "pnpm -r run build && node scripts/render-samples.mjs",
        "fixtures": "pnpm -r run build && node scripts/render-tests.mjs",
        "test": "pnpm -r run test",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "typecheck": "pnpm -r --if-present run typecheck",
        "lint:workflows": "actionlint",
        "langium:generate": "pnpm --filter @nowline/core run langium:generate"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.14",
        "typescript": "~5.7.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@vscode/vsce-sign",
            "esbuild",
            "keytar"
        ]
    }
}
