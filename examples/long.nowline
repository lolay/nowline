milestone beta "Beta" after:[pf-service-mesh, web-spa-upgrade]
milestone ga-launch "GA Launch" date:2026-12-15 after:[pf-api-gateway, sec-audit-log, data-warehouse]

footnote vendor-dep "Vendor dependency" on:sec-audit-log
  description "Blocked until vendor contract is signed. Expected March resolution."

footnote agent-rollout "Agent platform rollout" on:[pf-service-mesh, pf-agent-runtime, sci-retrieval]
  description "Shared program milestone across platform and science for the agent launch."
