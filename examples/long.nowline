nowline v1

config

scale
  name: weeks
  label-every: 4
  label: "W{n}"

style tech-debt-style
  bg: gray
  text: white

style near-term
  bg: blue
  text: white
  border: solid

style long-term
  bg: green
  text: white
  border: solid

default item shadow:subtle
default swimlane padding:sm spacing:none
default roadmap padding:md header-height:md font:sans timeline-position:both
default parallel bracket:none

roadmap long-2026 "Long Example 2026" author:"Acme Engineering" start:2026-01-05

duration xs length:1d
duration sm length:3d
duration md length:1w
duration lg length:2w
duration xl length:1m

label tech-debt "Tech debt" style:tech-debt-style
label agent "Agent" style:near-term
label self-service "Self-service" style:long-term

anchor kickoff date:2026-01-06
anchor mid-year "Mid-year Review" date:2026-07-01
anchor eoy "End of Year" date:2026-12-14

swimlane platform
  item pf-auth-refactor "Auth refactor" duration:lg after:kickoff status:done labels:tech-debt
  item pf-service-mesh "Service mesh" duration:xl after:pf-auth-refactor status:in-progress remaining:40% labels:agent
  item pf-api-gateway "API gateway" duration:lg after:pf-service-mesh labels:agent
  item pf-events "Event bus" duration:md
  item pf-caching "Caching tier" duration:md
  item pf-telemetry "Telemetry pipe" duration:md labels:tech-debt
  item pf-rate-limit "Rate limit rewrite" duration:sm
  item pf-logs "Log ingestion" duration:sm
  item pf-metrics "Metrics v2" duration:md
  item pf-tracing "Distributed tracing" duration:md labels:agent
  parallel after:pf-tracing
    group agent-platform-track "Agent platform track"
      item pf-agent-runtime "Agent runtime" duration:md labels:agent
      item pf-agent-sdk "Agent SDK" duration:md labels:agent
      item pf-agent-auth "Agent auth" duration:md labels:agent
      item pf-agent-observability "Agent observability" duration:md labels:[agent, tech-debt]
      item pf-agent-eval "Agent eval harness" duration:md labels:agent
    group self-service-framework "Self-service framework"
      item pf-ss-catalog "Service catalog" duration:md labels:self-service
      item pf-ss-onboarding "Self-service onboarding" duration:md labels:self-service
      item pf-ss-templates "Project templates" duration:md labels:self-service
      item pf-ss-quotas "Quota management" duration:md labels:self-service
      item pf-ss-billing "Self-service billing" duration:md labels:self-service

swimlane ios
  item ios-offline "Offline mode" duration:lg after:kickoff status:at-risk remaining:60%
  item ios-push "Push notifications" duration:md
  item ios-widgets "Home-screen widgets" duration:md labels:tech-debt
  item ios-deep-link "Deep linking" duration:sm
  item ios-performance "Performance pass" duration:md
  item ios-share "Share sheet" duration:sm
  item ios-biometric "Biometric auth" duration:md
  item ios-agent-surface "Agent entry point" duration:md labels:agent
  item ios-agent-voice "Agent voice mode" duration:md labels:agent
  item ios-watch "Watch companion" duration:lg
  item ios-carplay "CarPlay support" duration:lg
  item ios-ipad "iPad adaptation" duration:xl
  item ios-a11y "Accessibility pass" duration:md
  item ios-localization "Localization pass" duration:md
  item ios-onboarding "Onboarding v2" duration:md
  item ios-camera "Camera refactor" duration:md labels:tech-debt
  item ios-notifications "Notification center" duration:sm
  item ios-settings "Settings revamp" duration:md
  item ios-crash "Crash hardening" duration:sm
  item ios-agent-chat "Agent chat UI" duration:md labels:agent

swimlane android
  item and-offline "Offline sync" duration:lg after:kickoff status:in-progress remaining:55%
