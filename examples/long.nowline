  item sci-routing "Model routing" size:md
  item sci-caching "Inference cache" size:sm
  item sci-latency "Latency optimization" size:md
  item sci-memory "Long-term memory" size:md labels:agent
  item sci-tools "Tool-use framework" size:md labels:agent
  item sci-multimodal "Multimodal pipeline" size:lg
  item sci-cost "Cost optimization" size:md
  item sci-refresh "Data refresh cadence" size:sm

swimlane security
  item sec-audit-log "Audit log v2" size:xl after:kickoff status:at-risk remaining:25% labels:tech-debt
  item sec-sso "SSO hardening" size:lg
