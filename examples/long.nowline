swimlane infra
  item infra-k8s "Kubernetes upgrade" size:lg after:kickoff status:done labels:tech-debt
  item infra-ci "CI pipeline rewrite" size:lg labels:tech-debt
  item infra-cost "Cost reduction" size:md
  item infra-multi-region "Multi-region rollout" size:xl
  item infra-dr "Disaster recovery" size:lg
