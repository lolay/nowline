node_modules/
dist/
out/
dist-bin/
dist-deb/
packages/embed/dist-cdn-prod/
packages/embed/dist-cdn-dev/
# CI deploy lands the downloaded CDN artifact under the firebase project
# directory (so firebase.json's `"public": "public"` resolves without
# escaping the project dir). Local `firebase emulators:start` would write
# here too — keep it untracked.
packages/embed/firebase/prod/public/
packages/embed/firebase/dev/public/
*.tsbuildinfo
.scratch/
.pnpm-store/
.pnpm-bin/

# bun --compile intermediate cache (sometimes left in package roots)
*.bun-build

# Langium generated
**/src/generated/

# IDE
.vscode/
# Exception: the vscode-extension package ships a committed launch.json so
# F5 from inside that workspace launches the Extension Development Host with
# zero manual setup. See CONTRIBUTING.md "Working on the VS Code / Cursor
# extension" for the three iteration loops.
!/packages/vscode-extension/.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Logs
*.log

# Rendered example outputs (CLI artifacts, not source) — anchored to
# the root-level `examples/` folder so package-scoped example dirs
# (e.g. `packages/embed/examples/`) are not swept up.
/examples/**/*.svg
/examples/**/*.png
/examples/**/*.pdf
/examples/**/*.html
/examples/**/*.xlsx

# Rendered tests/ harness outputs (CLI artifacts, not source)
/tests/**/*.svg
/tests/**/*.png
/tests/**/*.pdf
/tests/**/*.html
/tests/**/*.xlsx
.cursor/plans
