# Rendered example outputs (CLI artifacts, not source) — anchored to
# the root-level `examples/` folder so package-scoped example dirs
# (e.g. `packages/embed/examples/`) are not swept up.
/examples/**/*.svg
/examples/**/*.png
/examples/**/*.pdf
/examples/**/*.html
/examples/**/*.xlsx

# Rendered tests/ harness outputs (CLI artifacts, not source)
/tests/**/*.svg
/tests/**/*.png
/tests/**/*.pdf
/tests/**/*.html
/tests/**/*.xlsx
.cursor/plans
