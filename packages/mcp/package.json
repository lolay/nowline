{
    "name": "@nowline/mcp",
    "mcpName": "io.nowline/nowline",
    "version": "0.8.4",
    "description": "Nowline MCP server — lets AI agents create, edit, and render your roadmaps.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "nowline-mcp": "./dist/index.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "prebuild": "node scripts/bundle-resources.mjs && node scripts/bundle-ui.mjs",
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@modelcontextprotocol/ext-apps": "^1.7.4",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@nowline/browser": "workspace:*",
        "@nowline/core": "workspace:*",
        "@nowline/export": "workspace:*",
        "@nowline/export-core": "workspace:*",
        "@nowline/layout": "workspace:*",
        "@nowline/preview": "workspace:*",
        "@nowline/preview-shell": "workspace:*",
        "@nowline/share-link": "workspace:*",
        "@resvg/resvg-wasm": "^2.6.2",
        "langium": "~4.2.4",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@modelcontextprotocol/inspector": "0.22.0",
        "@types/node": "^25.9.1",
        "esbuild": "^0.28.0",
        "vitest": "^4.1.7"
    }
}
