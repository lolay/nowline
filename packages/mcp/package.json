{
    "name": "@nowline/mcp",
    "version": "0.5.1",
    "description": "Nowline MCP server — stdio tool surface for validate/render/read/create/update/delete/list/export over local .nowline files",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "nowline-mcp": "./dist/index.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "prebuild": "node scripts/bundle-resources.mjs",
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@nowline/core": "workspace:*",
        "@nowline/export": "workspace:*",
        "@nowline/export-core": "workspace:*",
        "langium": "~4.2.4",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "vitest": "^4.1.7"
    }
}
