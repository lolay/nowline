{
    "name": "vscode-nowline",
    "displayName": "Nowline",
    "description": "Author Nowline roadmaps in VS Code and Cursor — syntax highlighting, language server, and live preview.",
    "version": "0.8.4",
    "private": false,
    "license": "Apache-2.0",
    "publisher": "nowline",
    "repository": {
        "type": "git",
        "url": "https://github.com/lolay/nowline.git",
        "directory": "packages/vscode-extension"
    },
    "homepage": "https://github.com/lolay/nowline",
    "bugs": {
        "url": "https://github.com/lolay/nowline/issues"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "keywords": [
        "nowline",
        "roadmap",
        "gantt",
        "planning",
        "dsl"
    ],
    "engines": {
        "node": ">=22",
        "pnpm": ">=11",
        "vscode": "^1.125.0"
    },
    "icon": "dist/icons/icon.png",
    "main": "./dist/extension.cjs",
    "contributes": {
        "languages": [
            {
                "id": "nowline",
                "aliases": [
                    "Nowline",
                    "nowline"
                ],
                "extensions": [
                    ".nowline"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/nowline-light.svg",
                    "dark": "./icons/nowline-dark.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "nowline",
                "scopeName": "source.nowline",
                "path": "./syntaxes/nowline.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "nowline",
                "path": "./snippets/nowline.json"
            }
        ],
        "configuration": {
            "title": "Nowline",
            "properties": {
                "nowline.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace LSP communication between VS Code and the bundled Nowline language server."
                },
                "nowline.ignoreRcFile": {
                    "type": "boolean",
                    "default": false,
                    "description": "When true, skip the .nowlinerc baseline lookup. The preview and Export… command then resolve options purely from VS Code settings + DSL directives + built-in defaults."
                },
                "nowline.preview.refreshOn": {
                    "type": "string",
                    "enum": [
                        "keystroke",
                        "save"
                    ],
                    "default": "keystroke",
                    "description": "When to re-render the live preview. 'keystroke' renders on every change (debounced); 'save' only on Cmd/Ctrl+S."
                },
                "nowline.preview.debounceMs": {
                    "type": "number",
                    "default": 200,
                    "minimum": 0,
                    "description": "Debounce window for keystroke-triggered re-renders, in milliseconds."
                },
                "nowline.preview.theme": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "light",
                        "dark",
                        "grayscale"
                    ],
                    "enumDescriptions": [
                        "Follow the active VS Code color theme (light/dark).",
                        "Force the light palette.",
                        "Force the dark palette.",
                        "Force the grayscale palette (achromatic; good for print)."
                    ],
                    "default": "auto",
                    "description": "Palette used to render the preview diagram. 'auto' follows the active VS Code color theme; 'light', 'dark', or 'grayscale' force a palette."
                },
                "nowline.preview.defaultFit": {
                    "type": "string",
                    "enum": [
                        "fitPage",
                        "fitWidth",
                        "actual"
                    ],
                    "default": "fitPage",
                    "description": "Initial fit when a preview opens. 'fitPage' shows the entire diagram; 'fitWidth' scales to the panel width; 'actual' uses 1:1 zoom."
                },
                "nowline.preview.showMinimap": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show a bottom-right minimap with a viewport indicator. The minimap auto-hides when the diagram fully fits inside the panel."
                },
                "nowline.preview.locale": {
                    "type": "string",
                    "default": "",
                    "pattern": "^$|^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$",
                    "patternErrorMessage": "Must be a BCP-47 language tag (e.g. 'fr', 'fr-CA') or empty.",
                    "description": "BCP-47 locale used to render the preview and validator messages. Empty falls through to .nowlinerc → vscode.env.language → 'en-US'. The file's `nowline v1 locale:` directive overrides this for the rendered SVG."
                },
                "nowline.preview.now": {
                    "type": "string",
                    "default": "auto",
                    "description": "Anchor for the now-line. 'auto' uses today's local civil date; 'none' suppresses the now-line entirely (mirrors `--now -`); 'YYYY-MM-DD' pins it to a specific date; a full ISO 8601 instant (e.g. '2026-06-05T06:00:00+07:00') sets an exact moment."
                },
                "nowline.preview.timezone": {
                    "type": "string",
                    "default": "",
                    "description": "Timezone for the clock-based 'today' default. Empty or 'local' uses the host zone (default). Accepts 'UTC', ISO 8601 offsets ('+05:30', 'Z'), or IANA names ('America/Los_Angeles'). Only consulted when nowline.preview.now is 'auto'."
                },
                "nowline.preview.strict": {
                    "type": "boolean",
                    "default": false,
                    "description": "Promote asset / sanitizer warnings to errors in the preview's diagnostic table. Mirrors the CLI's --strict flag."
                },
                "nowline.preview.showLinks": {
                    "type": "boolean",
                    "default": true,
                    "description": "Render link icons inside item bars. Inverse of the CLI's --no-links flag."
                },
                "nowline.preview.width": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "description": "Canvas width in pixels for the preview render. 0 leaves it unset (defaults to 1280); the preview's pan/zoom usually makes this irrelevant."
                },
                "nowline.preview.assetRoot": {
                    "type": "string",
                    "default": "",
                    "description": "Directory from which logo / image assets may be loaded. Empty uses the source file's directory (the same default the CLI uses without --asset-root)."
                },
                "nowline.export.cliPath": {
                    "type": "string",
                    "default": "nowline",
                    "description": "Optional override: path to an external `nowline` CLI binary. When set to anything other than the default 'nowline', the Export… command shells out to that binary instead of using the bundled in-process exporter. Supports ${workspaceFolder} substitution."
                },
                "nowline.export.pdf.pageSize": {
                    "type": "string",
                    "default": "letter",
                    "description": "PDF page size: a preset (letter, legal, tabloid, ledger, a1..a5, b3..b5), 'content' for auto-fit, or WxHunit for custom (e.g. 8.5x11in)."
                },
                "nowline.export.pdf.orientation": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "portrait",
                        "landscape"
                    ],
                    "default": "auto",
                    "description": "PDF page orientation."
                },
                "nowline.export.pdf.margin": {
                    "type": "string",
                    "default": "36pt",
                    "description": "PDF page margin. Bare numbers are points; length suffixes (in, mm, cm) are accepted (e.g. 36pt, 0.5in, 12mm)."
                },
                "nowline.export.fonts.sans": {
                    "type": "string",
                    "default": "",
                    "description": "Sans font for PNG/PDF export: a TTF/OTF path or alias (sf, helvetica, dejavu, …). Empty uses the platform font probe then the bundled DejaVu pair."
                },
                "nowline.export.fonts.mono": {
                    "type": "string",
                    "default": "",
                    "description": "Mono font for PNG/PDF export. Empty falls back to the same resolution chain as the sans font."
                },
                "nowline.export.fonts.headless": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip the platform font probe and force the bundled DejaVu pair. Yields byte-stable PNG/PDF output across machines."
                },
                "nowline.export.png.scale": {
                    "type": "number",
                    "default": 1,
                    "minimum": 0.1,
                    "description": "Raster scale factor for PNG export. This is the right knob for PNG resolution/DPI — it scales pixels without changing layout."
                },
                "nowline.export.width": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "description": "Canvas-width cap in px for exports (a maximum, not a target — the chart sizes to its natural content width and is clipped only if it exceeds this). 0 leaves it at the layout default (1280), matching the `nowline` CLI. Deliberately independent of the preview width (the preview's pan/zoom makes its width an ergonomic, not fidelity, choice). For PNG resolution use png.scale instead."
                },
                "nowline.export.msproj.start": {
                    "type": "string",
                    "default": "",
                    "pattern": "^$|^\\d{4}-\\d{2}-\\d{2}$",
                    "patternErrorMessage": "Must be empty or a YYYY-MM-DD date.",
                    "description": "MS Project export anchor date for relative roadmaps. Empty uses the same fallback chain as the CLI (--now → deterministic fallback)."
                }
            }
        },
        "commands": [
            {
                "command": "nowline.openLinkInSideBrowser",
                "title": "Open Link in Side Browser",
                "category": "Nowline"
            },
            {
                "command": "nowline.openPreview",
                "title": "Open Preview",
                "category": "Nowline",
                "icon": "$(open-preview)"
            },
            {
                "command": "nowline.openPreviewToSide",
                "title": "Open Preview to the Side",
                "category": "Nowline",
                "icon": "$(open-preview)"
            },
            {
                "command": "nowline.showSource",
                "title": "Show Source",
                "category": "Nowline",
                "icon": "$(go-to-file)"
            },
            {
                "command": "nowline.preview.expand",
                "title": "Expand Preview (Full Screen)",
                "category": "Nowline",
                "icon": "$(screen-full)"
            },
            {
                "command": "nowline.preview.collapse",
                "title": "Restore Preview Size",
                "category": "Nowline",
                "icon": "$(screen-normal)"
            },
            {
                "command": "nowline.export",
                "title": "Export…",
                "category": "Nowline",
                "icon": "$(export)"
            },
            {
                "command": "nowline.newRoadmap",
                "title": "New Roadmap…",
                "category": "Nowline"
            }
        ],
        "keybindings": [
            {
                "command": "nowline.openPreview",
                "key": "ctrl+shift+v",
                "mac": "cmd+shift+v",
                "when": "editorLangId == nowline"
            },
            {
                "command": "nowline.openPreviewToSide",
                "key": "ctrl+k v",
                "mac": "cmd+k v",
                "when": "editorLangId == nowline"
            }
        ],
        "submenus": [
            {
                "id": "nowline.context",
                "label": "Nowline",
                "icon": "$(open-preview)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "nowline.openPreviewToSide",
                    "when": "editorLangId == nowline",
                    "group": "navigation"
                },
                {
                    "command": "nowline.preview.expand",
                    "when": "activeWebviewPanelId == 'nowline.preview' && !nowline.previewMaximized",
                    "group": "navigation@0"
                },
                {
                    "command": "nowline.preview.collapse",
                    "when": "activeWebviewPanelId == 'nowline.preview' && nowline.previewMaximized",
                    "group": "navigation@0"
                },
                {
                    "command": "nowline.showSource",
                    "when": "activeWebviewPanelId == 'nowline.preview'",
                    "group": "navigation@1"
                },
                {
                    "command": "nowline.export",
                    "when": "editorLangId == nowline",
                    "group": "navigation"
                }
            ],
            "editor/title/context": [
                {
                    "submenu": "nowline.context",
                    "when": "resourceExtname == .nowline",
                    "group": "1_open"
                }
            ],
            "editor/context": [
                {
                    "submenu": "nowline.context",
                    "when": "editorLangId == nowline",
                    "group": "navigation"
                }
            ],
            "explorer/context": [
                {
                    "submenu": "nowline.context",
                    "when": "resourceExtname == .nowline",
                    "group": "navigation"
                }
            ],
            "nowline.context": [
                {
                    "command": "nowline.openPreview",
                    "group": "1_open@1"
                },
                {
                    "command": "nowline.openPreviewToSide",
                    "group": "1_open@2"
                },
                {
                    "command": "nowline.openLinkInSideBrowser",
                    "when": "editorLangId == nowline",
                    "group": "1_open@3"
                },
                {
                    "command": "nowline.export",
                    "group": "5_export@1"
                }
            ],
            "commandPalette": [
                {
                    "command": "nowline.export",
                    "when": "editorLangId == nowline || resourceExtname == .nowline"
                },
                {
                    "command": "nowline.showSource",
                    "when": "activeWebviewPanelId == 'nowline.preview'"
                },
                {
                    "command": "nowline.preview.expand",
                    "when": "activeWebviewPanelId == 'nowline.preview' && !nowline.previewMaximized"
                },
                {
                    "command": "nowline.preview.collapse",
                    "when": "activeWebviewPanelId == 'nowline.preview' && nowline.previewMaximized"
                },
                {
                    "command": "nowline.newRoadmap"
                }
            ]
        }
    },
    "scripts": {
        "sync-grammar": "node scripts/sync-grammar.mjs",
        "presync-grammar": "echo 'syncing grammar from grammars/'",
        "build-icon": "node scripts/build-icon.mjs",
        "prebuild": "node scripts/sync-grammar.mjs && node scripts/build-icon.mjs",
        "build": "node scripts/bundle.mjs",
        "watch": "node scripts/bundle.mjs --watch",
        "package": "node scripts/sync-grammar.mjs && node scripts/build-icon.mjs && NODE_ENV=production node scripts/bundle.mjs && vsce package --no-dependencies --out dist/nowline-vscode.vsix",
        "test": "node scripts/smoke-server.mjs && node scripts/smoke-extension.mjs",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@nowline/browser": "workspace:*",
        "@nowline/config": "workspace:*",
        "@nowline/core": "workspace:*",
        "@nowline/export": "workspace:*",
        "@nowline/export-core": "workspace:*",
        "@nowline/export-html": "workspace:*",
        "@nowline/export-mermaid": "workspace:*",
        "@nowline/export-msproj": "workspace:*",
        "@nowline/export-pdf": "workspace:*",
        "@nowline/export-xlsx": "workspace:*",
        "@nowline/layout": "workspace:*",
        "@nowline/lsp": "workspace:*",
        "@nowline/preview-shell": "workspace:*",
        "@nowline/renderer": "workspace:*",
        "@resvg/resvg-wasm": "^2.6.2",
        "langium": "~4.3.0",
        "vscode-languageclient": "^10.0.0"
    },
    "devDependencies": {
        "@resvg/resvg-js": "^2.6.2",
        "@types/node": "^25.9.3",
        "@types/vscode": "^1.125.0",
        "@vscode/vsce": "^3.9.2",
        "esbuild": "^0.28.1",
        "typescript": "^6.0.3"
    }
}
