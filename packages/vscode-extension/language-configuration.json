{
    "comments": {
        "lineComment": "//",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["[", "]"]
    ],
    "autoClosingPairs": [
        { "open": "[", "close": "]" },
        { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
    ],
    "surroundingPairs": [
        ["[", "]"],
        ["\"", "\""]
    ],
    "wordPattern": "[A-Za-z_][A-Za-z0-9_-]*",
    "onEnterRules": [
        {
            "beforeText": "^\\s*//.*$",
            "action": { "indent": "none" }
        }
    ]
}
