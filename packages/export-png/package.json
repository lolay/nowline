{
    "name": "@nowline/export-png",
    "version": "0.2.5",
    "description": "Nowline PNG exporter — rasterizes the renderer SVG via resvg-js (WASM)",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/export-core": "workspace:*",
        "@resvg/resvg-js": "^2.6.2"
    },
    "devDependencies": {
        "@nowline/core": "workspace:*",
        "@nowline/layout": "workspace:*",
        "@nowline/renderer": "workspace:*",
        "@types/node": "^25.9.1",
        "langium": "~4.2.4",
        "typescript": "~6.0.3",
        "vitest": "^4.1.7"
    }
}
