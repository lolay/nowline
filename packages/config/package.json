{
    "name": "@nowline/config",
    "version": "0.2.4",
    "description": "Shared .nowlinerc loader for the Nowline CLI and editors",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.0.0",
        "typescript": "~5.7.0",
        "vitest": "^3.1.0"
    }
}
