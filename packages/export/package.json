{
    "name": "@nowline/export",
    "version": "0.8.4",
    "description": "Nowline export engine — the single code path every tool shares, so a roadmap exports identically everywhere.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch"
    },
    "dependencies": {
        "@nowline/core": "workspace:*",
        "@nowline/export-core": "workspace:*",
        "@nowline/export-html": "workspace:*",
        "@nowline/export-mermaid": "workspace:*",
        "@nowline/export-msproj": "workspace:*",
        "@nowline/export-pdf": "workspace:*",
        "@nowline/export-png": "workspace:*",
        "@nowline/export-xlsx": "workspace:*",
        "@nowline/layout": "workspace:*",
        "@nowline/renderer": "workspace:*"
    },
    "peerDependencies": {
        "langium": "~4.2.4"
    },
    "devDependencies": {
        "@types/node": "^25.9.3",
        "langium": "~4.3.0",
        "typescript": "^6.0.3"
    }
}
