{
    "name": "@nowline/export-core",
    "version": "0.8.3",
    "description": "Shared building blocks for Nowline's exporters — fonts, units, page sizes, and common types.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./fonts": {
            "types": "./dist/fonts/index.d.ts",
            "import": "./dist/fonts/index.js"
        },
        "./units": {
            "types": "./dist/units.d.ts",
            "import": "./dist/units.js"
        },
        "./pdf-page": {
            "types": "./dist/pdf-page.d.ts",
            "import": "./dist/pdf-page.js"
        }
    },
    "files": [
        "dist/",
        "src/",
        "assets/"
    ],
    "scripts": {
        "bundle-fonts": "node scripts/bundle-fonts.mjs",
        "prebuild": "node scripts/bundle-fonts.mjs",
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "pretest": "node scripts/bundle-fonts.mjs",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/core": "workspace:*",
        "@nowline/layout": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    }
}
