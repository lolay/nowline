{
    "name": "@nowline/layout",
    "version": "0.1.0",
    "description": "Nowline layout engine — AST → positioned model for rendering",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/core": "workspace:*",
        "d3-scale": "^4.0.2",
        "d3-time": "^3.1.0"
    },
    "devDependencies": {
        "@types/d3-scale": "^4.0.8",
        "@types/d3-time": "^3.0.3",
        "langium": "~4.2.2",
        "typescript": "~5.7.0",
        "vitest": "^3.1.0"
    }
}
