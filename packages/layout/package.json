{
    "name": "@nowline/layout",
    "version": "0.8.1",
    "description": "Nowline layout engine — works out where everything goes on the page before it's drawn.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/core": "workspace:*",
        "d3-scale": "^4.0.2",
        "d3-time": "^3.1.0"
    },
    "devDependencies": {
        "@types/d3-scale": "^4.0.9",
        "@types/d3-time": "^3.0.4",
        "@types/node": "^25.9.1",
        "langium": "~4.2.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    }
}
