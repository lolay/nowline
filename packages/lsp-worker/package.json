{
    "name": "@nowline/lsp-worker",
    "version": "0.8.4",
    "description": "Runs the Nowline language server in a Web Worker, with a CodeMirror-friendly adapter for browser-based editors.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./worker": {
            "types": "./dist/worker.d.ts",
            "import": "./dist/worker.js"
        },
        "./client": {
            "types": "./dist/client.d.ts",
            "import": "./dist/client.js"
        },
        "./message-bridge": {
            "types": "./dist/message-bridge.d.ts",
            "import": "./dist/message-bridge.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/lolay/nowline.git",
        "directory": "packages/lsp-worker"
    },
    "homepage": "https://github.com/lolay/nowline",
    "bugs": {
        "url": "https://github.com/lolay/nowline/issues"
    },
    "keywords": [
        "nowline",
        "lsp",
        "language-server",
        "web-worker",
        "browser"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/core": "workspace:*",
        "@nowline/lsp": "workspace:*",
        "langium": "~4.3.0",
        "vscode-jsonrpc": "9.0.0",
        "vscode-languageserver": "~10.0.0",
        "vscode-languageserver-protocol": "~3.18.0"
    },
    "devDependencies": {
        "@types/node": "^25.9.3",
        "happy-dom": "^20.10.6",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9",
        "vscode-languageserver-types": "~3.18.0"
    }
}
