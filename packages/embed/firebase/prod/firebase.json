{
    "hosting": {
        "site": "nowline-embed-prod",
        "public": "public",
        "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
        "headers": [
            {
                "source": "/+([0-9]).+([0-9]).+([0-9])/nowline.min.@(js|js.map)",
                "headers": [
                    { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
                ]
            },
            {
                "source": "/+([0-9]).+([0-9])/nowline.min.@(js|js.map)",
                "headers": [
                    { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
                ]
            },
            {
                "source": "/latest/nowline.min.@(js|js.map)",
                "headers": [
                    { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
                ]
            },
            {
                "source": "/index.html",
                "headers": [
                    { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
                ]
            },
            {
                "source": "/versions.json",
                "headers": [
                    { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
                ]
            },
            {
                "source": "/@(+([0-9]).+([0-9]).+([0-9])|+([0-9]).+([0-9])|latest)/index.html",
                "headers": [
                    { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" },
                    { "key": "X-Robots-Tag", "value": "noindex" }
                ]
            }
        ]
    }
}
