{
    "hosting": {
        "site": "nowline-embed-dev",
        "public": "public",
        "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
        "headers": [
            {
                "source": "/latest/nowline.min.@(js|js.map)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=60, s-maxage=120, must-revalidate"
                    },
                    { "key": "X-Robots-Tag", "value": "noindex" }
                ]
            },
            {
                "source": "**/index.html",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=60, s-maxage=120, must-revalidate"
                    },
                    { "key": "X-Robots-Tag", "value": "noindex" }
                ]
            }
        ]
    }
}
