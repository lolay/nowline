{
    "name": "@nowline/cli",
    "version": "0.8.4",
    "description": "Command-line tool to check, convert, and create Nowline roadmaps.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "bin": {
        "nowline": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "man": [
        "./man/nowline.1",
        "./man/nowline.5"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "man/",
        "src/",
        "scripts/"
    ],
    "scripts": {
        "bundle-templates": "node scripts/bundle-templates.mjs",
        "prebuild": "node scripts/bundle-templates.mjs",
        "build": "tsc -b tsconfig.json",
        "postbuild": "node scripts/copy-wasm.mjs",
        "watch": "tsc -b tsconfig.json --watch",
        "pretest": "node scripts/bundle-templates.mjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "compile": "node scripts/compile.mjs",
        "compile:local": "node scripts/compile.mjs --target=local"
    },
    "dependencies": {
        "@babel/code-frame": "^8.0.0",
        "@clack/prompts": "^1.5.1",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@nowline/config": "workspace:*",
        "@nowline/core": "workspace:*",
        "@nowline/export": "workspace:*",
        "@nowline/export-core": "workspace:*",
        "@nowline/export-html": "workspace:*",
        "@nowline/export-mermaid": "workspace:*",
        "@nowline/export-msproj": "workspace:*",
        "@nowline/export-pdf": "workspace:*",
        "@nowline/export-png": "workspace:*",
        "@nowline/export-xlsx": "workspace:*",
        "@nowline/layout": "workspace:*",
        "@nowline/mcp": "workspace:*",
        "@nowline/renderer": "workspace:*",
        "chalk": "^5.6.2",
        "citty": "^0.2.2",
        "consola": "^3.4.2",
        "js-yaml": "^4.2.0",
        "langium": "~4.3.0"
    },
    "devDependencies": {
        "@resvg/resvg-wasm": "^2.6.2",
        "@types/babel__code-frame": "^7.27.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.9.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}
