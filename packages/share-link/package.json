{
    "name": "@nowline/share-link",
    "version": "0.8.3",
    "description": "Packs a Nowline roadmap into a shareable link — no server needed, the whole roadmap rides in the URL.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "fflate": "^0.8.3"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    }
}
