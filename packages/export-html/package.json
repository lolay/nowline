{
    "name": "@nowline/export-html",
    "version": "0.5.1",
    "description": "Nowline HTML exporter — self-contained HTML page wrapping the SVG with pan/zoom",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/export-core": "workspace:*"
    },
    "devDependencies": {
        "@nowline/core": "workspace:*",
        "@nowline/layout": "workspace:*",
        "@nowline/renderer": "workspace:*",
        "@types/node": "^25.9.1",
        "langium": "~4.2.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    }
}
