{
  "name": "@nowline/export-html",
  "version": "0.1.0",
  "description": "Nowline HTML exporter — self-contained HTML page wrapping the SVG with pan/zoom",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "watch": "tsc -b tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@nowline/export-core": "workspace:*"
  },
  "devDependencies": {
    "@nowline/core": "workspace:*",
    "@nowline/layout": "workspace:*",
    "@nowline/renderer": "workspace:*",
    "@types/node": "^22.0.0",
    "langium": "~4.2.2",
    "typescript": "~5.7.0",
    "vitest": "^3.1.0"
  }
}
