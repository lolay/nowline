{
    "name": "@nowline/lsp",
    "version": "0.8.4",
    "description": "Nowline language server — powers editor features like error checking, autocomplete, and hovers in VS Code, Cursor, and other editors.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "nowline-lsp": "./dist/server.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/core": "workspace:*",
        "langium": "~4.2.4",
        "vscode-languageserver": "~9.0.1",
        "vscode-languageserver-textdocument": "~1.0.12"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    }
}
