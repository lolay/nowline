{
    "name": "@nowline/lsp",
    "version": "0.8.5",
    "description": "Nowline language server — powers editor features like error checking, autocomplete, and hovers in VS Code, Cursor, and other editors.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=11"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "nowline-lsp": "./dist/server.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/core": "workspace:*",
        "langium": "~4.3.0",
        "vscode-languageserver": "~10.0.0",
        "vscode-languageserver-protocol": "~3.18.0",
        "vscode-languageserver-textdocument": "~1.0.12",
        "vscode-languageserver-types": "~3.18.0"
    },
    "devDependencies": {
        "@types/node": "^25.9.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}
