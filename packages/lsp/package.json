{
    "name": "@nowline/lsp",
    "version": "0.2.3",
    "description": "Nowline language-server — Langium-based LSP that powers VS Code, Cursor, and any other LSP-capable editor",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "nowline-lsp": "./dist/server.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js"
        }
    },
    "files": [
        "dist/",
        "src/"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.json",
        "watch": "tsc -b tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@nowline/core": "workspace:*",
        "langium": "~4.2.2",
        "vscode-languageserver": "~9.0.1",
        "vscode-languageserver-textdocument": "~1.0.12"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "~5.7.0",
        "vitest": "^3.1.0"
    }
}
